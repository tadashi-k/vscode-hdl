{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Verilog",
  "scopeName": "source.verilog",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.verilog",
          "match": "//.*$"
        },
        {
          "name": "comment.block.verilog",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.verilog",
          "match": "\\b(always|and|assign|automatic|begin|buf|bufif0|bufif1|case|casex|casez|cell|cmos|config|deassign|default|defparam|design|disable|edge|else|end|endcase|endconfig|endfunction|endgenerate|endmodule|endprimitive|endspecify|endtable|endtask|event|for|force|forever|fork|function|generate|genvar|highz0|highz1|if|ifnone|incdir|include|initial|inout|input|instance|integer|join|large|liblist|library|localparam|macromodule|medium|module|nand|negedge|nmos|nor|noshowcancelled|not|notif0|notif1|or|output|parameter|pmos|posedge|primitive|pull0|pull1|pulldown|pullup|pulsestyle_onevent|pulsestyle_ondetect|rcmos|real|realtime|reg|release|repeat|rnmos|rpmos|rtran|rtranif0|rtranif1|scalared|showcancelled|signed|small|specify|specparam|strong0|strong1|supply0|supply1|table|task|time|tran|tranif0|tranif1|tri|tri0|tri1|triand|trior|trireg|unsigned|use|uwire|vectored|wait|wand|weak0|weak1|while|wire|wor|xnor|xor)\\b"
        },
        {
          "name": "storage.type.verilog",
          "match": "\\b(reg|wire|integer|real|time|realtime|event|genvar|supply0|supply1|tri|triand|trior|tri0|tri1|trireg|wand|wor|uwire)\\b"
        },
        {
          "name": "constant.language.verilog",
          "match": "\\b(1'b0|1'b1|1'bx|1'bz|0|1)\\b"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.verilog",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.verilog",
          "match": "\\\\."
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.verilog",
          "match": "\\b[0-9]+'[bBoOdDhH][0-9a-fA-FxXzZ_]+\\b"
        },
        {
          "name": "constant.numeric.verilog",
          "match": "\\b[0-9][0-9_]*\\b"
        },
        {
          "name": "constant.numeric.verilog",
          "match": "\\b[0-9]+\\.[0-9]+([eE][+-]?[0-9]+)?\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.verilog",
          "match": "(\\+|\\-|\\*|\\/|%|\\^|&|\\||~|!|<<|>>|<=|>=|==|!=|===|!==|&&|\\|\\||\\?|:)"
        }
      ]
    }
  }
}
