{
  "name": "verilog-support",
  "displayName": "Verilog Language Support",
  "description": "Syntax highlighting for Verilog (*.v) files",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:verilog"
  ],
  "main": "./src/extension.js",
  "scripts": {
    "build:antlr": "node antlr/build.js",
    "clean:antlr": "rm -rf antlr/generated"
  },
  "contributes": {
    "languages": [
      {
        "id": "verilog",
        "aliases": [
          "Verilog",
          "verilog"
        ],
        "extensions": [
          ".v"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "verilog",
        "scopeName": "source.verilog",
        "path": "./syntaxes/verilog.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "verilog.showSymbols",
        "title": "Verilog: Show Symbols Database"
      }
    ]
  },
  "dependencies": {
    "antlr4": "^4.13.2",
    "antlr4ts": "^0.5.0-alpha.4",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "antlr4ts-cli": "^0.5.0-alpha.4"
  }
}
