{
  "name": "hdl-support",
  "displayName": "Verilog Language Support",
  "description": "",
  "version": "0.0.1",
  "publisher": "tadashi",
  "repository": {
    "type": "git",
    "url": "https://github.com/tadashi-k/vscode-hdl.git"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:verilog"
  ],
  "main": "./src/extension.js",
  "scripts": {
    "build:antlr": "node antlr/build.js",
    "clean:antlr": "rm -rf antlr/generated",
    "pack": "vsce pack"
  },
  "contributes": {
    "languages": [
      {
        "id": "verilog",
        "aliases": [
          "Verilog",
          "verilog"
        ],
        "extensions": [
          ".v"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "verilog",
        "scopeName": "source.verilog",
        "path": "./syntaxes/verilog.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "verilog.showSymbols",
        "title": "Verilog: Show Symbols Database"
      }
    ]
  },
  "dependencies": {
    "antlr4": "^4.8.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@types/vscode": "^1.109.0",
    "antlr4-tool": "^1.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
