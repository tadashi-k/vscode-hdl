{
  "name": "verilog-support",
  "displayName": "Verilog Language Support",
  "description": "Syntax highlighting for Verilog (*.v) files",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:verilog"
  ],
  "main": "./extension.js",
  "contributes": {
    "languages": [
      {
        "id": "verilog",
        "aliases": [
          "Verilog",
          "verilog"
        ],
        "extensions": [
          ".v"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "verilog",
        "scopeName": "source.verilog",
        "path": "./syntaxes/verilog.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "verilog.showSymbols",
        "title": "Verilog: Show Symbols Database"
      }
    ]
  }
}
