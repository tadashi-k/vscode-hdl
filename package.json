{
  "name": "hdl-support",
  "displayName": "Verilog/VHDL Language Support",
  "description": "",
  "version": "0.0.3",
  "publisher": "tadashi",
  "repository": {
    "type": "git",
    "url": "https://github.com/tadashi-k/vscode-hdl.git"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:verilog",
    "onLanguage:vhdl"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "build:antlr": "node antlr/build.js",
    "clean:antlr": "rm -rf antlr/generated",
    "build": "tsc -p tsconfig.json",
    "test": "node --import=tsx test/test_all.ts",
    "pack": "vsce package"
  },
  "contributes": {
    "languages": [
      {
        "id": "verilog",
        "aliases": [
          "Verilog",
          "verilog"
        ],
        "extensions": [
          ".v"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "vhdl",
        "aliases": ["VHDL", "vhdl"],
        "extensions": [".vhd", ".vhdl"],
        "configuration": "./vhdl-language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "verilog",
        "scopeName": "source.verilog",
        "path": "./syntaxes/verilog.tmLanguage.json"
      },
      {
        "language": "vhdl",
        "scopeName": "source.vhdl",
        "path": "./syntaxes/vhdl.tmLanguage.json"
      }
    ],
    "themes": [
      {
        "label": "Verilog HDL",
        "uiTheme": "vs-dark",
        "path": "./themes/verilog-hdl.json"
      }
    ],
    "commands": [
      {
        "command": "verilog.showSymbols",
        "title": "Verilog: Show Symbols Database"
      }
    ],
    "semanticTokenTypes": [
      {
        "id": "hdlReg",
        "description": "Verilog register signal",
        "superType": "variable"
      },
      {
        "id": "hdlWire",
        "description": "Verilog wire signal",
        "superType": "variable"
      },
      {
        "id": "hdlInteger",
        "description": "Verilog integer signal",
        "superType": "variable"
      },
      {
        "id": "hdlParameter",
        "description": "Verilog parameter",
        "superType": "variable"
      },
      {
        "id": "hdlModule",
        "description": "Verilog module name",
        "superType": "type"
      }
    ],
    "semanticTokenModifiers": [
      {
        "id": "hdlPort",
        "description": "Port signal (input/output/inout)"
      }
    ],
    "semanticTokenScopes": [
      {
        "language": "verilog",
        "scopes": {
          "hdlReg": [
            "variable.other.reg.verilog"
          ],
          "hdlWire": [
            "variable.other.wire.verilog"
          ],
          "hdlInteger": [
            "variable.other.integer.verilog"
          ],
          "hdlParameter": [
            "variable.other.constant.verilog"
          ],
          "hdlModule": [
            "entity.name.type.module.verilog"
          ]
        }
      },
      {
        "language": "vhdl",
        "scopes": {
          "hdlReg":       ["variable.other.variable.vhdl"],
          "hdlWire":      ["variable.other.signal.vhdl"],
          "hdlParameter": ["variable.other.constant.vhdl"],
          "hdlModule":    ["entity.name.type.entity.vhdl"]
        }
      }
    ],
    "configurationDefaults": {
      "[verilog]": {
        "editor.semanticHighlighting.enabled": true
      },
      "[vhdl]": {
        "editor.semanticHighlighting.enabled": true
      }
    }
  },
  "dependencies": {
    "antlr4": "^4.8.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@types/vscode": "^1.60.0",
    "antlr4-tool": "^1.1.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
