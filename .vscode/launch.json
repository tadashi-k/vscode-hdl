{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": [
        "${workspaceFolder}/**/*.js"
      ],
      "preLaunchTask": null
    },
    {
      "type": "pwa-node",
      "request": "launch",
      "name": "Debug test/test_directive.ts (tsx)",
      "program": "${workspaceFolder}/test/test_directive.ts",
      "runtimeArgs": [
        "--import=tsx"
      ],
      "runtimeExecutable": "node",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
